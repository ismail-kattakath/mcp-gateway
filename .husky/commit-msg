#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Conventional Commits validation
commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Pattern: type(optional-scope): lowercase subject
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .{1,}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Invalid commit message format"
  echo ""
  echo "Commit message must follow Conventional Commits:"
  echo "  type(optional-scope): subject"
  echo ""
  echo "Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo ""
  echo "Examples:"
  echo "  feat: add user authentication"
  echo "  fix: resolve memory leak in parser"
  echo "  docs(api): update REST API documentation"
  echo ""
  echo "Subject must start with lowercase letter"
  echo ""
  exit 1
fi

# Check subject starts with lowercase
if echo "$commit_msg" | grep -qE "^[a-z]+(\(.+\))?: [A-Z]"; then
  echo "❌ Commit subject must start with lowercase letter"
  echo ""
  echo "Bad:  feat: Add new feature"
  echo "Good: feat: add new feature"
  echo ""
  exit 1
fi

echo "✅ Commit message format valid"
