# Git files
.git
.gitignore
.gitattributes

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# NOTE: do NOT exclude package-lock.json — `npm ci` in the Dockerfile requires it
pnpm-lock.yaml

# Build outputs (will be generated during multi-stage build)
server/dist/
server/build/
ui/dist/
ui/build/

# Environment files
.env
.env.local
.env.development
.env.test
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*

# MCP data directories (mounted as volumes)
.mcp/
*.enc

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
coverage/
.nyc_output/
*.test.js
*.spec.js
__tests__/
__mocks__/
test/
tests/

# Documentation — skip all *.md to keep image small.
# CLAUDE.md is kept because the runtime image bundles registry.example.json,
# which references CLAUDE.md by relative path in a few comments. Not strictly
# required for runtime, but small and useful for `docker exec` introspection.
*.md
!CLAUDE.md
!README.md
docs/

# Claude Code project files
.claude/

# Temporary files
tmp/
temp/
*.tmp

# OS files
.DS_Store
Thumbs.db

# Docker files (no need to include in image)
Dockerfile
.dockerignore
docker-compose*.yml

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
circle.yml

# Misc
*.bak
*.old
*.orig
*.rej
