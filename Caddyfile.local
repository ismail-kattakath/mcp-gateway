# Local HTTPS for mcp-gateway via Caddy.
#
# Usage:
#   1. Add to /etc/hosts:    127.0.0.1   mcp.local
#   2. brew install caddy
#   3. caddy run --config Caddyfile.local
#   4. Trust Caddy's local CA (one time):    caddy trust
#   5. Point clients at https://mcp.local/sse
#
# Gateway should be bound to 127.0.0.1:3000 (the default in this repo).

mcp.local {
  # Use Caddy's internal CA (no Let's Encrypt — no public DNS required).
  tls internal

  # Allow your dev UI on http://localhost:5173 to call /api over HTTPS.
  # Add more origins as needed (Claude Desktop doesn't need CORS).
  @api path /api/* /sse /health /mcp/*
  header @api Access-Control-Allow-Origin "https://mcp.local"

  reverse_proxy 127.0.0.1:3000 {
    # Critical: never buffer the SSE stream.
    flush_interval -1

    # Pass through MCP-related headers untouched.
    header_up Host {host}
    header_up X-Real-IP {remote_host}
  }
}

# Optional: also serve plain https://localhost transparently
# (handy when a client refuses custom hostnames).
localhost {
  tls internal
  reverse_proxy 127.0.0.1:3000 {
    flush_interval -1
  }
}
