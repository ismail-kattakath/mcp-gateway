{
  "version": "2.0",
  "servers": {
    "obs": {
      "source": "pkg",
      "command": "npx",
      "args": ["-y", "obs-mcp@latest"],
      "env": {
        "OBS_WEBSOCKET_PASSWORD": "${OBS_WEBSOCKET_PASSWORD}"
      }
    },
    "github": {
      "source": "pkg",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "lifecycle": "persistent"
    },
    "custom-from-git": {
      "source": "git",
      "repo": "https://github.com/username/custom-mcp.git",
      "branch": "main",
      "command": "node",
      "args": ["${REPO_DIR}/dist/index.js"],
      "env": {
        "NODE_ENV": "production"
      },
      "enabled": false
    },
    "python-from-git": {
      "source": "git",
      "repo": "https://github.com/username/python-mcp.git",
      "tag": "v1.0.0",
      "command": "python3",
      "args": ["${REPO_DIR}/main.py"],
      "enabled": false
    },
    "comfyui": {
      "source": "container",
      "image": "ghcr.io/username/comfyui-mcp:latest",
      "volumes": ["${HOME}/.mcp/data:/data"],
      "ports": { "8188": 8189 },
      "env": {
        "API_KEY": "${CUSTOM_API_KEY}"
      },
      "lifecycle": "persistent",
      "enabled": false
    },
    "built-locally": {
      "source": "container",
      "build": {
        "repo": "https://github.com/username/mcp.git",
        "dockerfile": "Dockerfile",
        "context": "."
      },
      "ports": { "3000": 3001 },
      "enabled": false
    },
    "smithery-example": {
      "source": "remote",
      "transport": "sse",
      "url": "https://api.smithery.ai/servers/example/sse",
      "headers": {
        "Authorization": "Bearer ${SMITHERY_TOKEN}"
      },
      "lifecycle": "persistent",
      "enabled": false
    },
    "my-local-script": {
      "source": "local",
      "command": "python3",
      "args": ["${HOME}/scripts/my-mcp.py"],
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "enabled": false
    }
  },
  "gateway": {
    "server": {
      "port": 3000,
      "host": "0.0.0.0",
      "transport": "sse",
      "cors": {
        "enabled": true,
        "origins": ["*"],
        "credentials": true
      }
    },
    "storage": {
      "repos": "${HOME}/.mcp/repos",
      "cache": "${HOME}/.mcp/cache",
      "logs": "${HOME}/.mcp/logs"
    },
    "logging": {
      "level": "info",
      "format": "json",
      "outputs": ["console", "file"]
    },
    "enableAuth": false,
    "allowedIPs": []
  }
}
