{
  "dashboard": {
    "title": "MCP Gateway",
    "tags": ["mcp", "gateway"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{app=\"mcp-gateway\"}[5m])) by (status)",
            "legendFormat": "{{status}}"
          }
        ],
        "yaxes": [
          { "format": "reqps", "label": "Requests/sec" },
          { "format": "short" }
        ]
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{app=\"mcp-gateway\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{app=\"mcp-gateway\"}[5m]))",
            "legendFormat": "Error Rate"
          }
        ],
        "yaxes": [
          { "format": "percentunit", "label": "Error Rate" },
          { "format": "short" }
        ],
        "alert": {
          "name": "High Error Rate",
          "conditions": [
            {
              "evaluator": { "params": [0.05], "type": "gt" },
              "query": { "params": ["A", "5m", "now"] }
            }
          ]
        }
      },
      {
        "id": 3,
        "title": "Response Time (p50, p95, p99)",
        "type": "graph",
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{app=\"mcp-gateway\"}[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"mcp-gateway\"}[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{app=\"mcp-gateway\"}[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "yaxes": [
          { "format": "s", "label": "Duration" },
          { "format": "short" }
        ]
      },
      {
        "id": 4,
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "container_memory_usage_bytes{pod=~\"mcp-gateway.*\"}",
            "legendFormat": "{{pod}}"
          }
        ],
        "yaxes": [
          { "format": "bytes", "label": "Memory" },
          { "format": "short" }
        ]
      },
      {
        "id": 5,
        "title": "CPU Usage",
        "type": "graph",
        "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{pod=~\"mcp-gateway.*\"}[5m])",
            "legendFormat": "{{pod}}"
          }
        ],
        "yaxes": [
          { "format": "percentunit", "label": "CPU" },
          { "format": "short" }
        ]
      },
      {
        "id": 6,
        "title": "Active Connections",
        "type": "stat",
        "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(active_connections{app=\"mcp-gateway\"})"
          }
        ]
      },
      {
        "id": 7,
        "title": "Pod Count",
        "type": "stat",
        "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "count(kube_pod_info{pod=~\"mcp-gateway.*\"})"
          }
        ]
      },
      {
        "id": 8,
        "title": "MCP Tool Calls",
        "type": "graph",
        "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(mcp_tool_calls_total{app=\"mcp-gateway\"}[5m])) by (server, tool)",
            "legendFormat": "{{server}}/{{tool}}"
          }
        ],
        "yaxes": [
          { "format": "ops", "label": "Calls/sec" },
          { "format": "short" }
        ]
      },
      {
        "id": 9,
        "title": "Database Lock Wait Time",
        "type": "graph",
        "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(sqlite_lock_wait_seconds_total{app=\"mcp-gateway\"}[5m])",
            "legendFormat": "Lock Wait Time"
          }
        ],
        "yaxes": [
          { "format": "s", "label": "Seconds" },
          { "format": "short" }
        ]
      },
      {
        "id": 10,
        "title": "Server Status",
        "type": "table",
        "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "mcp_server_status{app=\"mcp-gateway\"}",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true
              }
            }
          }
        ]
      }
    ]
  }
}
