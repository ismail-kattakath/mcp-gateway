# Example GitHub Actions workflow for testing Docker build
# Rename to docker-test.yml and place in .github/workflows/ to enable

name: Docker Build Test

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main ]

jobs:
  docker-build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Set up Docker Buildx
      uses: docker/setup-buildx-action@v3

    - name: Copy example configs
      run: |
        cp .env.example .env
        cp registry.example.json registry.json

    - name: Build Docker image
      run: docker build -t mcp-gateway:test .

    - name: Test image layers
      run: docker history mcp-gateway:test

    - name: Run validation script
      run: chmod +x docker-validate.sh && ./docker-validate.sh

    - name: Test docker-compose
      run: docker-compose config

    - name: Test production compose
      run: docker-compose -f docker-compose.prod.yml config

  docker-security:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Run Trivy vulnerability scanner
      uses: aquasecurity/trivy-action@master
      with:
        scan-type: 'config'
        scan-ref: '.'
        format: 'sarif'
        output: 'trivy-results.sarif'

    - name: Upload Trivy results
      uses: github/codeql-action/upload-sarif@v3
      with:
        sarif_file: 'trivy-results.sarif'
