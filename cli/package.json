{
  "name": "mcp-gateway-cli",
  "version": "2.1.0",
  "description": "Command-line interface for MCP Gateway",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "gateway",
    "cli",
    "model-context-protocol"
  ],
  "author": "ismail-kattakath",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "keytar": "^7.9.0",
    "ora": "^8.0.1",
    "table": "^6.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
