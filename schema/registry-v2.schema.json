{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mcp-gateway.dev/schema/registry-v2.json",
  "title": "MCP Gateway Registry",
  "description": "Configuration schema for MCP Gateway server registry",
  "type": "object",
  "required": ["version", "servers", "gateway"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0",
      "description": "Registry schema version"
    },
    "servers": {
      "type": "object",
      "description": "MCP server configurations, keyed by server name",
      "patternProperties": {
        "^[a-z0-9][a-z0-9-]*[a-z0-9]$": {
          "oneOf": [
            { "$ref": "#/definitions/PkgServer" },
            { "$ref": "#/definitions/GitServer" },
            { "$ref": "#/definitions/ContainerServer" },
            { "$ref": "#/definitions/RemoteServer" },
            { "$ref": "#/definitions/LocalServer" }
          ]
        }
      },
      "additionalProperties": false
    },
    "gateway": {
      "type": "object",
      "required": ["server", "storage", "logging"],
      "additionalProperties": false,
      "properties": {
        "server":   { "$ref": "#/definitions/ServerConfig" },
        "storage":  { "$ref": "#/definitions/StorageConfig" },
        "logging":  { "$ref": "#/definitions/LoggingConfig" },
        "security": { "$ref": "#/definitions/SecurityConfig" }
      }
    }
  },

  "definitions": {
    "BaseServerFields": {
      "description": "Fields shared by all server source types. All optional with defaults applied by the loader.",
      "type": "object",
      "properties": {
        "lifecycle": {
          "type": "string",
          "enum": ["on-demand", "persistent"],
          "default": "on-demand",
          "description": "When to spawn the server: on-demand (lazy) or persistent (always running)"
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether this server is active"
        },
        "timeout": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 300000,
          "default": 30000,
          "description": "Server spawn / request timeout in milliseconds"
        }
      }
    },

    "EnvMap": {
      "type": "object",
      "description": "Environment variables. Keys must be UPPER_SNAKE_CASE. Values support ${VAR} substitution from .env and system env.",
      "patternProperties": {
        "^[A-Z_][A-Z0-9_]*$": { "type": "string" }
      },
      "additionalProperties": false
    },

    "PkgServer": {
      "description": "Server installed and run via a package manager (npx, uvx, pipx, etc.). Version goes inline in args (e.g. 'obs-mcp@1.2.3').",
      "type": "object",
      "required": ["source", "command", "args"],
      "additionalProperties": false,
      "properties": {
        "source":    { "const": "pkg" },
        "command":   { "type": "string", "minLength": 1, "description": "Package manager binary, e.g. 'npx', 'uvx', 'pipx'" },
        "args":      { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "Args including the package name (with optional @version)" },
        "env":       { "$ref": "#/definitions/EnvMap" },
        "lifecycle": { "$ref": "#/definitions/BaseServerFields/properties/lifecycle" },
        "enabled":   { "$ref": "#/definitions/BaseServerFields/properties/enabled" },
        "timeout":   { "$ref": "#/definitions/BaseServerFields/properties/timeout" }
      }
    },

    "GitServer": {
      "description": "Server cloned from a git repo, then installed/built (auto-detected from repo contents) and run with the given command.",
      "type": "object",
      "required": ["source", "repo", "command", "args"],
      "additionalProperties": false,
      "oneOf": [
        { "not": { "anyOf": [{ "required": ["branch"] }, { "required": ["tag"] }, { "required": ["commit"] }] } },
        { "required": ["branch"], "not": { "anyOf": [{ "required": ["tag"] }, { "required": ["commit"] }] } },
        { "required": ["tag"],    "not": { "anyOf": [{ "required": ["branch"] }, { "required": ["commit"] }] } },
        { "required": ["commit"], "not": { "anyOf": [{ "required": ["branch"] }, { "required": ["tag"] }] } }
      ],
      "properties": {
        "source": { "const": "git" },
        "repo":   { "type": "string", "pattern": "^(https?://|git@)[^\\s]+\\.git$", "description": "Git repository URL (HTTPS or SSH)" },
        "branch": { "type": "string", "description": "Git branch to checkout (mutually exclusive with tag and commit). Default: remote HEAD." },
        "tag":    { "type": "string", "description": "Git tag to checkout (mutually exclusive with branch and commit)" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{7,40}$", "description": "Commit hash (mutually exclusive with branch and tag)" },
        "install": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Optional override for install step. If omitted, auto-detected: npm install (package.json), uv pip install -e . (pyproject.toml), uv pip install -r requirements.txt."
        },
        "build": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Optional override for build step. If omitted, auto-detected: npm run build when scripts.build exists."
        },
        "command":   { "type": "string", "minLength": 1, "description": "Runtime command to execute the built artifact, e.g. 'node', 'python3', 'bun'" },
        "args":      { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "Args for the runtime command. Use ${REPO_DIR} to reference the clone location." },
        "env":       { "$ref": "#/definitions/EnvMap" },
        "lifecycle": { "$ref": "#/definitions/BaseServerFields/properties/lifecycle" },
        "enabled":   { "$ref": "#/definitions/BaseServerFields/properties/enabled" },
        "timeout":   { "$ref": "#/definitions/BaseServerFields/properties/timeout" }
      }
    },

    "ContainerServer": {
      "description": "Server run as a Docker container. Exactly one of `image` or `build` must be provided.",
      "type": "object",
      "required": ["source"],
      "additionalProperties": false,
      "oneOf": [
        { "required": ["image"], "not": { "required": ["build"] } },
        { "required": ["build"], "not": { "required": ["image"] } }
      ],
      "properties": {
        "source": { "const": "container" },
        "image":  { "type": "string", "description": "Container image reference, e.g. 'ghcr.io/user/img:tag'" },
        "pull": {
          "type": "string",
          "enum": ["always", "missing", "never"],
          "default": "missing",
          "description": "When to pull the image. Ignored when `build` is used."
        },
        "build": {
          "type": "object",
          "required": ["dockerfile"],
          "additionalProperties": false,
          "properties": {
            "repo":       { "type": "string", "pattern": "^(https?://|git@)[^\\s]+\\.git$", "description": "Optional git repo to clone before building. If omitted, builds from local context." },
            "dockerfile": { "type": "string", "default": "Dockerfile", "description": "Path to Dockerfile relative to context" },
            "context":    { "type": "string", "default": ".", "description": "Build context directory" },
            "args":       { "type": "object", "additionalProperties": { "type": "string" }, "description": "Docker build args (--build-arg)" }
          }
        },
        "volumes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[^:]+:[^:]+(:r[ow])?$",
            "description": "Volume mount in host:container[:ro|rw] format"
          }
        },
        "ports": {
          "type": "object",
          "description": "Port mapping: container port -> host port",
          "patternProperties": {
            "^[0-9]+$": { "type": "integer", "minimum": 1, "maximum": 65535 }
          },
          "additionalProperties": false
        },
        "env":       { "$ref": "#/definitions/EnvMap" },
        "lifecycle": { "$ref": "#/definitions/BaseServerFields/properties/lifecycle" },
        "enabled":   { "$ref": "#/definitions/BaseServerFields/properties/enabled" },
        "timeout":   { "$ref": "#/definitions/BaseServerFields/properties/timeout" }
      }
    },

    "RemoteServer": {
      "description": "Remote MCP server reached over HTTP (SSE or plain HTTP). Nothing executes locally.",
      "type": "object",
      "required": ["source", "url", "transport"],
      "additionalProperties": false,
      "properties": {
        "source":    { "const": "remote" },
        "transport": { "type": "string", "enum": ["sse", "http"], "description": "Transport protocol" },
        "url":       { "type": "string", "format": "uri", "pattern": "^https?://", "description": "Remote endpoint URL" },
        "method":    { "type": "string", "enum": ["GET", "POST"], "default": "POST", "description": "HTTP method (only meaningful when transport is 'http')" },
        "headers":   { "type": "object", "additionalProperties": { "type": "string" }, "description": "Custom HTTP headers (values support ${VAR} substitution)" },
        "lifecycle": { "$ref": "#/definitions/BaseServerFields/properties/lifecycle" },
        "enabled":   { "$ref": "#/definitions/BaseServerFields/properties/enabled" },
        "timeout":   { "$ref": "#/definitions/BaseServerFields/properties/timeout" }
      }
    },

    "LocalServer": {
      "description": "Server run from a pre-existing file or script on disk. Subsumes shell scripts (command: 'bash', args: ['script.sh']).",
      "type": "object",
      "required": ["source", "command"],
      "additionalProperties": false,
      "properties": {
        "source":    { "const": "local" },
        "command":   { "type": "string", "minLength": 1, "description": "Interpreter or executable to run" },
        "args":      { "type": "array", "items": { "type": "string" } },
        "env":       { "$ref": "#/definitions/EnvMap" },
        "lifecycle": { "$ref": "#/definitions/BaseServerFields/properties/lifecycle" },
        "enabled":   { "$ref": "#/definitions/BaseServerFields/properties/enabled" },
        "timeout":   { "$ref": "#/definitions/BaseServerFields/properties/timeout" }
      }
    },

    "ServerConfig": {
      "type": "object",
      "required": ["port", "host", "transport"],
      "additionalProperties": false,
      "properties": {
        "port":      { "type": "integer", "minimum": 1, "maximum": 65535, "default": 3000 },
        "host":      { "type": "string", "default": "127.0.0.1", "description": "Bind address. Default 127.0.0.1 (loopback only — put Caddy/nginx in front for HTTPS or remote access). Set to '0.0.0.0' only if you intentionally want to expose the gateway directly." },
        "transport": { "type": "string", "enum": ["sse", "http", "both"], "default": "sse" },
        "cors": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":     { "type": "boolean", "default": true },
            "origins":     { "type": "array", "items": { "type": "string" }, "default": ["*"] },
            "credentials": { "type": "boolean", "default": true }
          }
        }
      }
    },

    "StorageConfig": {
      "type": "object",
      "required": ["repos", "cache", "logs"],
      "additionalProperties": false,
      "properties": {
        "repos": { "type": "string", "description": "Directory for cloned git repos (supports ${HOME})" },
        "cache": { "type": "string", "description": "Directory for build cache" },
        "logs":  { "type": "string", "description": "Directory for log files" }
      }
    },

    "LoggingConfig": {
      "type": "object",
      "required": ["level", "format", "outputs"],
      "additionalProperties": false,
      "properties": {
        "level":   { "type": "string", "enum": ["debug", "info", "warn", "error"], "default": "info" },
        "format":  { "type": "string", "enum": ["json", "text"], "default": "json" },
        "outputs": { "type": "array", "items": { "type": "string", "enum": ["console", "file"] }, "minItems": 1 }
      }
    },

    "SecurityConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apiKey":     { "type": "string", "description": "Gateway API key for remote access (supports ${VAR})" },
        "enableAuth": { "type": "boolean", "default": false },
        "allowedIPs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}(/[0-9]{1,2})?$" }
        }
      }
    }
  }
}
