{
  "name": "mcp-gateway-server",
  "version": "2.1.0",
  "description": "MCP Gateway Server - Universal aggregator for Model Context Protocol servers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "validate": "node src/validation/validate-registry.js",
    "benchmark:logging": "tsx src/logging-v3/benchmark.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gateway",
    "proxy",
    "server"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
