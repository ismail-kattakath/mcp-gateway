# MCP Gateway Environment Configuration
# Copy to .env and fill in your values

# ===== Gateway Server =====
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
GATEWAY_API_KEY=your-secret-key-here
LOG_LEVEL=info

# ===== OAuth Providers =====
# GitHub OAuth (for github backend)
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/oauth/github/callback

# Smithery OAuth (for smithery-hosted MCPs)
# Get from: https://smithery.ai/settings/oauth
SMITHERY_CLIENT_ID=
SMITHERY_CLIENT_SECRET=
SMITHERY_REDIRECT_URI=http://localhost:3000/oauth/smithery/callback

# Note: Access tokens are auto-managed by OAuth flow and stored encrypted
# You can reference them in registry.json as ${GITHUB_ACCESS_TOKEN} or ${SMITHERY_ACCESS_TOKEN}

# ===== Backend MCP Secrets =====
# OBS Studio
OBS_WEBSOCKET_PASSWORD=

# ComfyUI
COMFYUI_API_URL=http://localhost:8188

# Add your custom MCP secrets here
# CUSTOM_API_KEY=
# ANOTHER_SECRET=

# ===== Storage Paths =====
MCP_REPOS_DIR=${HOME}/.mcp/repos
MCP_CACHE_DIR=${HOME}/.mcp/cache
MCP_LOGS_DIR=${HOME}/.mcp/logs
MCP_TOKENS_FILE=${HOME}/.mcp/tokens.enc

# ===== Security =====
# Auto-generated if not provided (64 hex chars = 32 bytes)
# Generate manually: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
ENABLE_AUTH=false
ALLOWED_IPS=
