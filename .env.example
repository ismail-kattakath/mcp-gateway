# MCP Gateway Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Gateway Server Settings
# ============================================

# Server port (default: 3000)
# GATEWAY_PORT=3000

# Server host (default: 0.0.0.0)
# GATEWAY_HOST=0.0.0.0

# Transport mode: sse, http, or both (default: sse)
# GATEWAY_TRANSPORT=sse

# ============================================
# Logging
# ============================================

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# ============================================
# CORS Settings
# ============================================

# CORS origins (comma-separated, default: *)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# CORS credentials (default: true)
# CORS_CREDENTIALS=true

# ============================================
# Development Settings
# ============================================

# Disable stdio detection (force HTTP mode)
# DISABLE_STDIO=true

# ============================================
# MCP Server Environment Variables
# ============================================
# These are substituted in registry.json via ${VAR}

# OBS WebSocket password
# OBS_WEBSOCKET_PASSWORD=your-password

# GitHub Personal Access Token
# GITHUB_TOKEN=ghp_your_token

# Smithery API token
# SMITHERY_TOKEN=your-token

# Custom API keys
# CUSTOM_API_KEY=your-key
