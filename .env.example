# MCP Gateway Environment Configuration
# Copy to .env and fill in your values

# ===== Gateway Server =====
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
GATEWAY_API_KEY=your-secret-key-here
LOG_LEVEL=info

# ===== OAuth Providers =====
# GitHub OAuth (for github backend)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Auto-managed by OAuth flow:
GITHUB_ACCESS_TOKEN=
GITHUB_REFRESH_TOKEN=

# Smithery OAuth (for smithery-hosted MCPs)
SMITHERY_CLIENT_ID=
SMITHERY_CLIENT_SECRET=
# Auto-managed by OAuth flow:
SMITHERY_ACCESS_TOKEN=
SMITHERY_REFRESH_TOKEN=

# ===== Backend MCP Secrets =====
# OBS Studio
OBS_WEBSOCKET_PASSWORD=

# ComfyUI
COMFYUI_API_URL=http://localhost:8188

# Add your custom MCP secrets here
# CUSTOM_API_KEY=
# ANOTHER_SECRET=

# ===== Storage Paths =====
MCP_REPOS_DIR=${HOME}/.mcp/repos
MCP_CACHE_DIR=${HOME}/.mcp/cache
MCP_LOGS_DIR=${HOME}/.mcp/logs
MCP_TOKENS_FILE=${HOME}/.mcp/tokens.enc

# ===== Security =====
TOKEN_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
ENABLE_AUTH=false
ALLOWED_IPS=
